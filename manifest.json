{
  "manifest_version": 3,
  "name": "ETH Lecture Copilot",
  "version": "1.0.0",
  "description": "AI-powered lecture guide & Q&A sidebar for ETH Zürich video.ethz.ch",

  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://video.ethz.ch/*",
    "https://dist.tobira.ethz.ch/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*"
  ],

  "background": {
    "service_worker": "background/background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://video.ethz.ch/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ETH Lecture Copilot"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "sidebar/sidebar.html",
        "sidebar/sidebar.css",
        "sidebar/sidebar.js",
        "lib/katex/katex.min.js",
        "lib/katex/katex.min.css",
        "lib/katex/auto-render.min.js",
        "lib/katex/fonts/*"
      ],
      "matches": ["https://video.ethz.ch/*"]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
