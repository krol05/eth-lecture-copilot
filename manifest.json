{
  "manifest_version": 3,
  "name": "ETH Lecture Copilot",
  "version": "1.2.1",
  "description": "AI-powered lecture guide & Q&A sidebar for ETH Zürich video.ethz.ch",

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-eval'; object-src 'self';"
  },

  "permissions": ["storage", "unlimitedStorage", "activeTab", "scripting"],
  "host_permissions": [
    "https://video.ethz.ch/*",
    "https://dist.tobira.ethz.ch/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*",
    "https://api.x.ai/*",
    "https://api.deepseek.com/*",
    "https://api.mistral.ai/*",
    "https://openrouter.ai/*",
    "https://api.groq.com/*",
    "https://api.together.xyz/*",
    "https://api.cerebras.ai/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://cdn.jsdelivr.net/*",
    "https://huggingface.co/*"
  ],

  "background": {
    "service_worker": "background/background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://video.ethz.ch/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ETH Lecture Copilot"
  },
  "options_page": "ui/ui-settings.html",

  "web_accessible_resources": [
    {
      "resources": [
        "sidebar/sidebar.html",
        "sidebar/sidebar.css",
        "sidebar/sidebar.js",
        "sidebar/scripts.js",
        "sidebar/print-guide.html",
        "sidebar/print-guide.css",
        "sidebar/print-guide.js",
        "lib/ui-settings.js",
        "lib/providers-config.js",
        "lib/katex/katex.min.js",
        "lib/katex/katex.min.css",
        "lib/katex/auto-render.min.js",
        "lib/katex/fonts/*",
        "lib/pdfjs/pdf.min.mjs",
        "lib/pdfjs/pdf.worker.min.mjs",
        "lib/transformers/transformers.min.js",
        "lib/transformers/ort.bundle.min.mjs",
        "lib/transformers/ort-wasm-simd-threaded.jsep.mjs",
        "lib/transformers/ort-wasm-simd-threaded.jsep.wasm",
        "ui/ui-settings.html",
        "ui/ui-settings.css",
        "ui/ui-settings.js"
      ],
      "matches": ["https://video.ethz.ch/*"]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
